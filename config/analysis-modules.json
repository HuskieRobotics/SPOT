[
  {
    "view": "team",
    "module": "PerformanceTimePlot",
    "name": "Robot Action Counts Each Match",
    "position": "main",
    "options": {
      "trackedStats": [
        "counts.shooting",
        "counts.passing",
        "counts.storing",
        "counts.defense"
      ]
    }
  },
  {
    "view": "team",
    "module": "RadarChart",
    "name": "Ratings By Time Intervals",
    "position": "main",
    "options": {
      "sections": [
        {
          "name": "Auto"
        },
        {
          "name": "Transition"
        },
        {
          "name": "Active 1"
        },
        {
          "name": "Active 2"
        },
        {
          "name": "Inactive 1"
        },
        {
          "name": "Inactive 2"
        },
        {
          "name": "Endgame"
        },
        {
          "name": "Auto"
        }
      ],
      "lines": [
        {
          "name": "Shooting",
          "times": [
            {
              "name": "Auto",
              "path": "averageScores.autoShootingRating"
            },
            {
              "name": "Transition",
              "path": "averageScores.teleopTransitionShootingRating"
            },
            {
              "name": "Active 1",
              "path": "averageScores.activeShift1ShootingRating"
            },
            {
              "name": "Active 2",
              "path": "averageScores.activeShift2ShootingRating"
            },
            { "name": "Inactive 1", "path": "none" },
            { "name": "Inactive 2", "path": "none" },
            {
              "name": "Endgame",
              "path": "averageScores.endgameShootingRating"
            },
            {
              "name": "Auto",
              "path": "averageScores.autoShootingRating"
            }
          ]
        },
        {
          "name": "Collecting",
          "times": [
            {
              "name": "Auto",
              "path": "none"
            },
            {
              "name": "Transition",
              "path": "averageScores.teleopTransitionStoringRating"
            },
            {
              "name": "Active 1",
              "path": "averageScores.activeShift1StoringRating"
            },
            {
              "name": "Active 2",
              "path": "averageScores.activeShift2StoringRating"
            },
            {
              "name": "Inactive 1",
              "path": "averageScores.inactiveShift1StoringRating"
            },
            {
              "name": "Inactive 2",
              "path": "averageScores.inactiveShift2StoringRating"
            },
            {
              "name": "Endgame",
              "path": "averageScores.endgameStoringRating"
            },
            {
              "name": "Auto",
              "path": "none"
            }
          ]
        },
        {
          "name": "Passing",
          "times": [
            {
              "name": "Auto",
              "path": "averageScores.autoPassingRating"
            },
            {
              "name": "Transition",
              "path": "averageScores.teleopTransitionPassingRating"
            },
            {
              "name": "Active 1",
              "path": "averageScores.activeShift1PassingRating"
            },
            {
              "name": "Active 2",
              "path": "averageScores.activeShift2PassingRating"
            },
            {
              "name": "Inactive 1",
              "path": "averageScores.inactiveShift1PassingRating"
            },

            {
              "name": "Inactive 2",
              "path": "averageScores.inactiveShift2PassingRating"
            },
            {
              "name": "Endgame",
              "path": "averageScores.endgamePassingRating"
            },
            {
              "name": "Auto",
              "path": "averageScores.autoPassingRating"
            }
          ]
        },
        {
          "name": "Defense",
          "times": [
            { "name": "Auto", "path": "none" },
            {
              "name": "Transition",
              "path": "averageScores.teleopTransitionDefenseRating"
            },
            {
              "name": "Active 1",
              "path": "averageScores.activeShift1DefenseRating"
            },
            {
              "name": "Active 2",
              "path": "averageScores.activeShift2DefenseRating"
            },
            {
              "name": "Inactive 1",
              "path": "averageScores.inactiveShift1DefenseRating"
            },

            {
              "name": "Inactive 2",
              "path": "averageScores.inactiveShift2DefenseRating"
            },
            {
              "name": "Endgame",
              "path": "averageScores.endgameDefenseRating"
            },
            { "name": "Auto", "path": "none" }
          ]
        }
      ]
    }
  },

  {
    "view": "team",
    "module": "HeatmapScatterPlot",
    "name": "Teleop Shooting Heatmap",
    "position": "main",
    "options": {
      "coordinatePath": "other.pos",
      "aggregatedActionsPath": "aggregatedActions",
      "actionGroups": [
        {
          "name": "Teleop Start Shooting",
          "actions": [
            "teleopTransitionStartShooting",
            "activeShift1StartShooting",
            "activeShift2StartShooting",
            "endgameStartShooting"
          ]
        }
      ],
      "actionLabels": {
        "teleopTransitionStartShooting": "Transition",
        "activeShift1StartShooting": "Active 1",
        "activeShift2StartShooting": "Active 2",
        "endgameStartShooting": "Endgame"
      },
      "imgPath": "img/half-field.svg"
    }
  },
  {
    "view": "team",
    "module": "Bar",
    "name": "Attempted Climb Level",
    "position": "main",
    "options": {
      "bars": [
        {
          "name": "Fall",
          "path": "counts.endgameFall"
        },
        {
          "name": "L1",
          "path": "counts.endgameAttemptL1"
        },

        {
          "name": "L2",
          "path": "counts.endgameAttemptL2"
        },
        {
          "name": "L3",
          "path": "counts.endgameAttemptL3"
        }
      ]
    }
  },
  {
    "view": "team",
    "module": "Bar",
    "name": "TBA Climb Levels",
    "position": "main",
    "options": {
      "bars": [
        {
          "name": "L1",
          "path": "counts.endGameTowerRobot_Level1"
        },
        {
          "name": "L2",
          "path": "counts.endGameTowerRobot_Level2"
        },
        {
          "name": "L3",
          "path": "counts.endGameTowerRobot_Level3"
        }
      ]
    }
  },
  {
    "view": "team",
    "module": "Pie",
    "name": "Pre-Loads",
    "position": "main",
    "options": {
      "slices": [
        {
          "name": "Pre-Loaded Fuel",
          "path": "counts.preloadFuel"
        },
        {
          "name": "Pre-Load None",
          "path": "counts.preloadNone"
        }
      ]
    }
  },
  {
    "view": "team",
    "module": "Pie",
    "name": "Average Action Times",
    "position": "main",
    "options": {
      "unit": "s",
      "slices": [
        {
          "name": "Shooting",
          "path": "cycles.shootingTime.averageTimeSeconds"
        },
        {
          "name": "Passing",
          "path": "cycles.passingTime.averageTimeSeconds"
        },
        {
          "name": "Collecting",
          "path": "cycles.storingTime.averageTimeSeconds"
        },
        {
          "name": "Defense",
          "path": "cycles.defenseTime.averageTimeSeconds"
        }
      ]
    }
  },
  {
    "view": "team",
    "module": "Stats",
    "position": "side",
    "name": "Team Stats",
    "options": {
      "list": [
        {
          "name": "Fuel OPR",
          "path": "opr.Hub Total Fuel Count",
          "decimals": 2,
          "sort": 1
        },
        {
          "name": "Minor Foul OPR",
          "path": "opr.minorFoulCount",
          "decimals": 2,
          "sort": -1
        },
        {
          "name": "Major Foul OPR",
          "path": "opr.majorFoulCount",
          "decimals": 2,
          "sort": -1
        },
        {
          "name": "Average Passing Rating",
          "path": "averageScores.passingRating",
          "decimals": 2,
          "sort": 1
        },
        {
          "name": "Average Defense Rating",
          "path": "averageScores.defenseRating",
          "decimals": 2,
          "sort": 1
        },
        {
          "name": "Average Shooting Rating",
          "path": "averageScores.shootingRating",
          "decimals": 2,
          "sort": 1
        },
        {
          "name": "Average Collecting Rating",
          "path": "averageScores.storingRating",
          "decimals": 2,
          "sort": 1
        },
        {
          "name": "Average Auto Shooting Rating",
          "path": "averageScores.autoShootingRating",
          "decimals": 2,
          "sort": 1
        },
        {
          "name": "Average Auto Passing Rating",
          "path": "averageScores.autoPassingRating",
          "decimals": 2,
          "sort": 1
        },
        {
          "name": "Average Auto Shooting Time",
          "path": "cycles.autoShootingTime.averageTime",
          "multiplier": 0.001,
          "decimals": 2,
          "hideIfValue": 0,
          "sort": -1,
          "unit": "s"
        },
        {
          "name": "Average Teleop Shooting Time",
          "path": "cycles.shootingTime.averageTime",
          "multiplier": 0.001,
          "decimals": 2,
          "hideIfValue": 0,
          "sort": -1,
          "unit": "s"
        },
        {
          "name": "Average Climb Time",
          "path": "averageTimes.attemptClimbTime",
          "multiplier": 0.001,
          "decimals": 2,
          "sort": -1,
          "unit": "s"
        }
      ]
    }
  },
  {
    "view": "match",
    "module": "ColumnDisplay",
    "name": "Auto Climb Points",
    "position": "main",
    "options": {
      "path": "averageScores.auto",
      "sort": 1,
      "decimals": 2
